<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BLite.Studio.ViewModels"
        xmlns:ex="using:BLite.Studio.ViewModels.Explorer"
        xmlns:core="using:BLite.Core"
        xmlns:Bson="using:BLite.Bson"
        xmlns:converters="using:BLite.Studio.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="640"
        x:Class="BLite.Studio.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="BLite Studio"
        Width="900" Height="680"
        MinWidth="640" MinHeight="480"
        WindowStartupLocation="CenterScreen">

  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*">

    <!-- ── Toolbar ──────────────────────────────────────────────────── -->
    <Border Grid.Row="0"
            Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,0,0,1"
            Padding="16,10">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <TextBlock Text="BLite" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
          <TextBlock Text="Studio" FontSize="18" FontWeight="Light" VerticalAlignment="Center"/>
          <TextBlock Text="—" Margin="8,0" Opacity="0.4" VerticalAlignment="Center"
                     IsVisible="{Binding IsDatabaseOpen}"/>
          <TextBlock Text="{Binding OpenDatabaseName}"
                     FontSize="14" VerticalAlignment="Center" Opacity="0.7"
                     IsVisible="{Binding IsDatabaseOpen}"/>
        </StackPanel>
        <TextBlock Grid.Column="1"
                   Text="{Binding AppVersion}"
                   FontSize="11" Opacity="0.35"
                   VerticalAlignment="Center"
                   Margin="16,0,0,0"/>
      </Grid>
    </Border>

    <!-- ── Body ─────────────────────────────────────────────────────── -->
    <Grid Grid.Row="1">

      <!-- ══ Open database panel ══════════════════════════════════ -->
      <ScrollViewer IsVisible="{Binding !IsDatabaseOpen}" Padding="32,28,32,32">
        <StackPanel MaxWidth="560" Spacing="0">

          <TextBlock Text="Open database" FontSize="22" FontWeight="SemiBold"
                     Margin="0,0,0,4"/>
          <TextBlock Text="Select a BLite database file and configure the access options."
                     Opacity="0.6" Margin="0,0,0,24" TextWrapping="Wrap"/>

          <!-- File path row -->
          <TextBlock Text="Database file" FontWeight="SemiBold" Margin="0,0,0,6"/>
          <Grid ColumnDefinitions="*,Auto">
            <TextBox Grid.Column="0"
                     Text="{Binding DatabasePath}"
                     Watermark="Percorso del file (qualsiasi estensione)…"
                     VerticalContentAlignment="Center"/>
            <Button Grid.Column="1"
                    Content="Browse…"
                    Margin="8,0,0,0"
                    Click="Browse_Click"/>
          </Grid>
          <TextBlock Text="Any file extension is accepted (.db, .blite, etc.)"
                     FontSize="11" Opacity="0.5" Margin="0,4,0,0"/>

          <Separator Margin="0,20,0,18"/>

          <!-- Preset -->
          <TextBlock Text="Page configuration" FontWeight="SemiBold" Margin="0,0,0,10"/>
          <Grid ColumnDefinitions="*,*,*">
            <Border Grid.Column="0" Classes="PresetCard" Margin="0,0,6,0">
              <StackPanel>
                <RadioButton Content="Small" GroupName="Preset"
                             IsChecked="{Binding IsPresetSmall}" FontWeight="SemiBold"/>
                <TextBlock Text="8 KB page · 512 KB growth" FontSize="11" Opacity="0.6" Margin="28,0,0,0"/>
                <TextBlock Text="Small documents" FontSize="11" Opacity="0.5" Margin="28,2,0,0"/>
              </StackPanel>
            </Border>
            <Border Grid.Column="1" Classes="PresetCard" Margin="3,0">
              <StackPanel>
                <RadioButton Content="Default" GroupName="Preset"
                             IsChecked="{Binding IsPresetDefault}" FontWeight="SemiBold"/>
                <TextBlock Text="16 KB page · 1 MB growth" FontSize="11" Opacity="0.6" Margin="28,0,0,0"/>
                <TextBlock Text="Balanced (recommended)" FontSize="11" Opacity="0.5" Margin="28,2,0,0"/>
              </StackPanel>
            </Border>
            <Border Grid.Column="2" Classes="PresetCard" Margin="6,0,0,0">
              <StackPanel>
                <RadioButton Content="Large" GroupName="Preset"
                             IsChecked="{Binding IsPresetLarge}" FontWeight="SemiBold"/>
                <TextBlock Text="32 KB page · 2 MB growth" FontSize="11" Opacity="0.6" Margin="28,0,0,0"/>
                <TextBlock Text="Large documents" FontSize="11" Opacity="0.5" Margin="28,2,0,0"/>
              </StackPanel>
            </Border>
          </Grid>

          <Border Background="{DynamicResource SystemControlBackgroundAltMediumHighBrush}"
                  CornerRadius="6" Padding="14,8" Margin="0,10,0,0">
            <Grid ColumnDefinitions="Auto,*,Auto,*">
              <TextBlock Grid.Column="0" Text="Page size:" Opacity="0.6" Margin="0,0,12,0"/>
              <TextBlock Grid.Column="1" Text="{Binding PageSizeDisplay}" FontWeight="SemiBold" Margin="0,0,24,0"/>
              <TextBlock Grid.Column="2" Text="Growth block:" Opacity="0.6" Margin="0,0,12,0"/>
              <TextBlock Grid.Column="3" Text="{Binding GrowthBlockDisplay}" FontWeight="SemiBold"/>
            </Grid>
          </Border>

          <Separator Margin="0,20,0,18"/>

          <!-- Access mode -->
          <TextBlock Text="Access mode" FontWeight="SemiBold" Margin="0,0,0,8"/>
          <StackPanel Orientation="Horizontal" Spacing="24">
            <RadioButton Content="Read / Write" GroupName="Access" IsChecked="{Binding IsReadWrite}"/>
            <RadioButton Content="Read only"   GroupName="Access" IsChecked="{Binding IsReadOnly}"/>
          </StackPanel>

          <!-- Error -->
          <Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                  Background="#1FE53935" BorderBrush="#80E53935" BorderThickness="1"
                  CornerRadius="6" Padding="12,8" Margin="0,18,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#E53935" TextWrapping="Wrap" FontSize="12"/>
          </Border>

          <!-- Open button -->
          <Button Content="Open database"
                  Classes="accent"
                  Command="{Binding OpenDatabaseCommand}"
                  HorizontalAlignment="Right"
                  Margin="0,20,0,0"
                  Padding="20,8"/>

          <!-- ── Recent connections ──────────────────────────── -->
          <StackPanel IsVisible="{Binding HasRecentConnections}" Margin="0,32,0,0">
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,10">
              <TextBlock Grid.Column="0"
                         Text="Recent" FontSize="16" FontWeight="SemiBold"
                         VerticalAlignment="Center"/>
            </Grid>

            <ItemsControl ItemsSource="{Binding RecentConnections}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:RecentConnectionViewModel">
                  <Border Classes="RecentCard" Margin="0,0,0,6">
                    <Grid ColumnDefinitions="*,Auto">

                      <!-- Clickable left area -->
                      <Button Grid.Column="0"
                              Classes="RecentCardBtn"
                              Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OpenRecentCommand}"
                              CommandParameter="{Binding}"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Stretch">
                        <Grid ColumnDefinitions="*,Auto">
                          <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="{Binding DisplayName}"
                                       FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Text="{Binding FilePath}"
                                       FontSize="11" Opacity="0.5"
                                       TextTrimming="CharacterEllipsis"/>
                          </StackPanel>
                          <StackPanel Grid.Column="1"
                                      Orientation="Horizontal"
                                      Spacing="10"
                                      VerticalAlignment="Center"
                                      Margin="16,0,0,0">
                            <Border Classes="Tag">
                              <TextBlock Text="{Binding PresetLabel}" FontSize="10"/>
                            </Border>
                            <Border Classes="Tag">
                              <TextBlock Text="{Binding AccessLabel}" FontSize="10"/>
                            </Border>
                            <Border Classes="Tag" IsVisible="{Binding IsMultiFile}">
                              <TextBlock Text="Multi-file" FontSize="10"/>
                            </Border>
                            <TextBlock Text="{Binding RelativeTime}"
                                       FontSize="11" Opacity="0.5"
                                       VerticalAlignment="Center"/>
                          </StackPanel>
                        </Grid>
                      </Button>

                      <!-- Remove button -->
                      <Button Grid.Column="1"
                              Content="✕"
                              Classes="RecentRemoveBtn"
                              Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).RemoveRecentCommand}"
                              CommandParameter="{Binding}"
                              ToolTip.Tip="Remove from recents"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>

          <!-- ── About ──────────────────────────────────────────── -->
          <Border Margin="0,40,0,8"
                  BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                  BorderThickness="0,1,0,0"
                  Padding="0,20,0,0">
            <StackPanel Spacing="6">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                  <TextBlock Text="BLite Studio" FontWeight="SemiBold" FontSize="12"/>
                  <TextBlock Text="{Binding AppVersion}"
                             FontSize="12" Opacity="0.5"/>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="MIT License · © 2026 BLite Project"
                           FontSize="11" Opacity="0.4"
                           VerticalAlignment="Center"/>
              </Grid>
              <Expander Header="View license text" FontSize="11">
                <Border Margin="0,8,0,0"
                        Background="{DynamicResource SystemControlBackgroundAltMediumHighBrush}"
                        CornerRadius="4"
                        Padding="12">
                  <ScrollViewer MaxHeight="160">
                    <TextBlock Text="{Binding AppLicense}"
                               FontFamily="Consolas,'Courier New',monospace"
                               FontSize="10"
                               Opacity="0.7"
                               TextWrapping="Wrap"/>
                  </ScrollViewer>
                </Border>
              </Expander>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>

      <!-- ══ Connected panel ══════════════════════════════════════ -->
      <Grid IsVisible="{Binding IsDatabaseOpen}" RowDefinitions="Auto,*">

        <!-- Top bar -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
              <StackPanel Spacing="1">
                <TextBlock Text="{Binding OpenDatabaseName}" FontWeight="SemiBold" FontSize="14"/>
                <TextBlock Text="{Binding DatabasePath}" FontSize="11" Opacity="0.5"
                           TextTrimming="CharacterEllipsis" MaxWidth="400"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="Page:" Opacity="0.5" FontSize="11" VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding PageSizeDisplay}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="Growth:" Opacity="0.5" FontSize="11" VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding GrowthBlockDisplay}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="Access:" Opacity="0.5" FontSize="11" VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding AccessModeDisplay}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4"
                            IsVisible="{Binding IsMultiFile}">
                  <TextBlock Text="Layout:" Opacity="0.5" FontSize="11" VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding LayoutDisplay}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
              </StackPanel>
            </StackPanel>
            <Button Grid.Column="1"
                    Content="Disconnect"
                    Command="{Binding CloseDatabaseCommand}"
                    VerticalAlignment="Center"/>
          </Grid>
        </Border>

        <!-- Master / Detail -->
        <Grid Grid.Row="1" ColumnDefinitions="220,Auto,*">

          <!-- ── Sidebar (master) ──────────────────────────── -->
          <Border Grid.Column="0"
                  Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                  Padding="0,8,0,0">
            <ScrollViewer>
              <StackPanel Spacing="2">

                <!-- Field Keys item -->
                <Button Classes="NavItem"
                        Classes.NavItemActive="{Binding Explorer.SidebarItems[0].IsSelected}"
                        Command="{Binding Explorer.SelectItemCommand}"
                        CommandParameter="{Binding Explorer.SidebarItems[0]}"
                        HorizontalAlignment="Stretch">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="#" FontWeight="Bold" Opacity="0.6"/>
                    <TextBlock Text="Field Keys"/>
                  </StackPanel>
                </Button>

                <!-- Key-Value Store item -->
                <Button Classes="NavItem"
                        Classes.NavItemActive="{Binding Explorer.SidebarItems[1].IsSelected}"
                        Command="{Binding Explorer.SelectItemCommand}"
                        CommandParameter="{Binding Explorer.SidebarItems[1]}"
                        HorizontalAlignment="Stretch">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="🗝" Opacity="0.7"/>
                    <TextBlock Text="Key-Value Store"/>
                  </StackPanel>
                </Button>

                <!-- Collections section -->
                <StackPanel Margin="12,16,12,4" Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="COLLECTIONS"
                             FontSize="10" FontWeight="SemiBold"
                             Opacity="0.4" VerticalAlignment="Center"
                             LetterSpacing="1"/>
                  <Border Classes="Tag" IsVisible="{Binding Explorer.HasCollections}">
                    <TextBlock Text="{Binding Explorer.CollectionCount}" FontSize="10"/>
                  </Border>
                  <Button Content="↻"
                          Command="{Binding Explorer.RefreshCommand}"
                          Classes="NavRefreshBtn"
                          ToolTip.Tip="Refresh"
                          Margin="4,0,0,0"/>
                </StackPanel>

                <!-- Collection items -->
                <ItemsControl ItemsSource="{Binding Explorer.CollectionItems}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="ex:SidebarItemViewModel">
                      <Button Classes="NavItem"
                              Classes.NavItemActive="{Binding IsSelected}"
                              Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Explorer.SelectItemCommand}"
                              CommandParameter="{Binding}"
                              HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                          <TextBlock Text="≡" Opacity="0.5"/>
                          <TextBlock Text="{Binding Label}"
                                     TextTrimming="CharacterEllipsis"/>
                          <Border CornerRadius="3" Padding="4,1"
                                  Background="#1E6B3C"
                                  IsVisible="{Binding IsTimeSeries}"
                                  VerticalAlignment="Center">
                            <TextBlock Text="TS" FontSize="9" FontWeight="Bold"
                                       Foreground="#55DD88"
                                       VerticalAlignment="Center"/>
                          </Border>
                        </StackPanel>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state -->
                <TextBlock IsVisible="{Binding !Explorer.HasCollections}"
                           Text="No collections found"
                           FontSize="11" Opacity="0.4"
                           Margin="12,4"/>

              </StackPanel>
            </ScrollViewer>
          </Border>

          <!-- Vertical divider -->
          <Border Grid.Column="1" Width="1"
                  Background="{DynamicResource SystemControlForegroundBaseLowBrush}"
                  Opacity="0.5"/>

          <!-- ── Detail panel ──────────────────────────────── -->
          <ContentControl Grid.Column="2"
                          Content="{Binding Explorer.DetailContent}">
            <ContentControl.DataTemplates>

              <!-- KV Store detail -->
              <DataTemplate DataType="ex:KvStoreDetailViewModel">
                <Grid RowDefinitions="Auto,*">

                  <!-- Header -->
                  <StackPanel Grid.Row="0" Spacing="8" Margin="20,14,20,8">
                    <TextBlock Text="Key-Value Store" FontSize="18" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                      <Border Classes="StatCard">
                        <StackPanel Spacing="2">
                          <TextBlock Text="Entries" FontSize="11" Opacity="0.5"/>
                          <TextBlock Text="{Binding EntryCount}" FontSize="20" FontWeight="SemiBold"/>
                        </StackPanel>
                      </Border>
                    </StackPanel>
                  </StackPanel>

                  <!-- Content -->
                  <Grid Grid.Row="1" ColumnDefinitions="*,Auto">

                    <!-- List pane -->
                    <DockPanel Grid.Column="0">

                      <!-- Toolbar -->
                      <Border DockPanel.Dock="Top"
                              Padding="8,6"
                              BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                              BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="*,Auto,Auto">
                          <TextBox Grid.Column="0"
                                   Text="{Binding ScanPrefix}"
                                   Watermark="Filter by prefix…"
                                   VerticalContentAlignment="Center"
                                   Margin="0,0,8,0"/>
                          <Button Grid.Column="1"
                                  Content="↻ Refresh"
                                  Command="{Binding RefreshCommand}"
                                  Margin="0,0,8,0"/>
                          <Button Grid.Column="2"
                                  Content="+ New Entry"
                                  Command="{Binding NewEntryCommand}"/>
                        </Grid>
                      </Border>

                      <!-- Bottom bar -->
                      <Border DockPanel.Dock="Bottom"
                              BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                              BorderThickness="0,1,0,0"
                              Padding="12,6">
                        <Grid ColumnDefinitions="Auto,*">
                          <Button Grid.Column="0"
                                  Content="🗑 Purge Expired"
                                  Command="{Binding PurgeExpiredCommand}"
                                  Margin="0,0,12,0"/>
                          <TextBlock Grid.Column="1"
                                     Text="{Binding StatusMessage}"
                                     VerticalAlignment="Center"
                                     FontSize="12"
                                     TextWrapping="Wrap"
                                     Classes.MsgErr="{Binding StatusIsError}"
                                     Classes.MsgOk="{Binding StatusIsOk}"
                                     IsVisible="{Binding StatusMessage,
                                         Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        </Grid>
                      </Border>

                      <!-- Table -->
                      <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                              BorderThickness="0,1,0,0">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                          <StackPanel>
                            <!-- Header row -->
                            <Grid ColumnDefinitions="110,*,80,180"
                                  Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
                              <TextBlock Grid.Column="0" Text="Actions"
                                         FontWeight="SemiBold" FontSize="12" Margin="10,7"/>
                              <TextBlock Grid.Column="1" Text="Key"
                                         FontWeight="SemiBold" FontSize="12"
                                         FontFamily="Monospace" Margin="8,7"/>
                              <TextBlock Grid.Column="2" Text="Size"
                                         FontWeight="SemiBold" FontSize="12" Margin="8,7"/>
                              <TextBlock Grid.Column="3" Text="Value preview"
                                         FontWeight="SemiBold" FontSize="12" Margin="8,7"/>
                            </Grid>
                            <!-- Rows -->
                            <ItemsControl ItemsSource="{Binding Entries}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="ex:KvEntryRowViewModel">
                                  <Grid ColumnDefinitions="110,*,80,180" Classes="DocRow">
                                    <StackPanel Grid.Column="0"
                                                Orientation="Horizontal"
                                                Spacing="4" Margin="6,4">
                                      <Button Content="Open"
                                              FontSize="11" Padding="6,2"
                                              Command="{Binding $parent[ItemsControl].((ex:KvStoreDetailViewModel)DataContext).OpenEntryCommand}"
                                              CommandParameter="{Binding}"/>
                                      <Button Content="✕"
                                              FontSize="11" Padding="6,2"
                                              Classes="DangerBtn"
                                              Command="{Binding $parent[ItemsControl].((ex:KvStoreDetailViewModel)DataContext).DeleteEntryCommand}"
                                              CommandParameter="{Binding}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Key}"
                                               FontFamily="Monospace" FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" Margin="8,0"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding SizeDisplay}"
                                               FontFamily="Monospace" FontSize="11" Opacity="0.65"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center" Margin="4,0,8,0"/>
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding ValuePreview}"
                                               FontSize="11" Opacity="0.7"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" Margin="8,0"/>
                                  </Grid>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </StackPanel>
                        </ScrollViewer>
                      </Border>

                    </DockPanel>

                    <!-- Right panel: viewer / insert form -->
                    <Border Grid.Column="1"
                            Width="380"
                            IsVisible="{Binding IsPanelOpen}"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                            BorderThickness="1,0,0,0">
                      <DockPanel>

                        <!-- Panel header -->
                        <Grid DockPanel.Dock="Top"
                              ColumnDefinitions="*,Auto"
                              Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                              Height="36">
                          <TextBlock Grid.Column="0"
                                     Text="{Binding PanelTitle}"
                                     FontFamily="Monospace" FontSize="12"
                                     TextTrimming="CharacterEllipsis"
                                     VerticalAlignment="Center" Margin="12,0"/>
                          <Button Grid.Column="1"
                                  Content="✕" Padding="8,0" Height="36"
                                  Command="{Binding ClosePanelCommand}"/>
                        </Grid>

                        <!-- Panel footer -->
                        <Border DockPanel.Dock="Bottom"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="10,6">
                          <Grid ColumnDefinitions="*,Auto,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding StatusMessage}"
                                       VerticalAlignment="Center" FontSize="12"
                                       TextWrapping="Wrap"
                                       Classes.MsgErr="{Binding StatusIsError}"
                                       Classes.MsgOk="{Binding StatusIsOk}"
                                       IsVisible="{Binding StatusMessage,
                                           Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            <!-- Delete — visible when viewing -->
                            <Button Grid.Column="1"
                                    Content="🗑 Delete"
                                    Classes="DangerBtn"
                                    IsVisible="{Binding !IsInsertMode}"
                                    Command="{Binding DeleteEntryCommand}"
                                    CommandParameter="{Binding SelectedEntry}"
                                    Margin="0,0,8,0"/>
                            <!-- Save — visible when inserting -->
                            <Button Grid.Column="2"
                                    Content="💾 Save"
                                    IsVisible="{Binding IsInsertMode}"
                                    Command="{Binding SaveEntryCommand}"/>
                          </Grid>
                        </Border>

                        <!-- Viewer (read-only value display) -->
                        <TextBox IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Text="{Binding ViewerValue}"
                                 FontFamily="Monospace" FontSize="11"
                                 BorderThickness="0" CornerRadius="0"
                                 IsVisible="{Binding !IsInsertMode}"/>

                        <!-- Insert form -->
                        <ScrollViewer IsVisible="{Binding IsInsertMode}" Padding="12">
                          <StackPanel Spacing="12">

                            <StackPanel Spacing="4">
                              <TextBlock Text="Key" FontWeight="SemiBold" FontSize="12"/>
                              <TextBox Text="{Binding NewKey}"
                                       FontFamily="Monospace" FontSize="12"
                                       Watermark="e.g. session:user-42"
                                       VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Spacing="4">
                              <TextBlock Text="Value (UTF-8 text)" FontWeight="SemiBold" FontSize="12"/>
                              <TextBox AcceptsReturn="True"
                                       TextWrapping="Wrap"
                                       MinHeight="80"
                                       Text="{Binding NewValue}"
                                       FontFamily="Monospace" FontSize="12"
                                       Watermark="Enter any text or JSON…"/>
                            </StackPanel>

                            <CheckBox Content="Set expiry (TTL)"
                                      IsChecked="{Binding HasNewTtl}"/>

                            <StackPanel Spacing="4" IsVisible="{Binding HasNewTtl}">
                              <TextBlock Text="TTL (hours)" FontSize="12" Opacity="0.6"/>
                              <NumericUpDown Value="{Binding NewTtlHours}"
                                             Minimum="0.001"
                                             Maximum="876000"
                                             Increment="1"
                                             FormatString="0.###"/>
                            </StackPanel>

                          </StackPanel>
                        </ScrollViewer>

                      </DockPanel>
                    </Border>

                  </Grid>
                </Grid>
              </DataTemplate>

              <!-- Field Keys detail -->
              <DataTemplate DataType="ex:FieldKeysDetailViewModel">
                <Grid RowDefinitions="Auto,*" Margin="24,20">
                  <StackPanel Grid.Row="0" Spacing="10" Margin="0,0,0,14">
                    <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                      <TextBlock Grid.Column="0"
                                 Text="Field Keys" FontSize="18" FontWeight="SemiBold"/>
                      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                                  VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding FilteredCount}" Opacity="0.5" FontSize="12"/>
                        <TextBlock Text=" / " Opacity="0.4" FontSize="12"/>
                        <TextBlock Text="{Binding TotalCount}" Opacity="0.5" FontSize="12"/>
                        <TextBlock Text=" keys" Opacity="0.4" FontSize="12"/>
                      </StackPanel>
                    </Grid>
                    <TextBox Text="{Binding SearchText}"
                             Watermark="Search field names…"/>
                  </StackPanel>
                  <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding FilteredKeys}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="ex:FieldKeyEntry">
                          <Grid ColumnDefinitions="*,Auto"
                                Margin="0,0,0,1">
                            <Border Grid.ColumnSpan="2"
                                    Classes="KeyRow"/>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Name}"
                                       FontSize="13" Margin="10,6"
                                       FontFamily="Monospace"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Id}"
                                       FontSize="11" Margin="16,6,10,6"
                                       Opacity="0.45"
                                       VerticalAlignment="Center"/>
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </Grid>
              </DataTemplate>

              <!-- Collection detail -->
              <DataTemplate DataType="ex:CollectionDetailViewModel">
                <Grid RowDefinitions="Auto,*">

                  <!-- ── Header ── -->
                  <StackPanel Grid.Row="0" Spacing="8" Margin="20,14,20,8">
                    <TextBlock Text="{Binding Name}"
                               FontSize="18" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                      <Border Classes="StatCard">
                        <StackPanel Spacing="2">
                          <TextBlock Text="Documents" FontSize="11" Opacity="0.5"/>
                          <TextBlock Text="{Binding DocumentCount}"
                                     FontSize="20" FontWeight="SemiBold"/>
                        </StackPanel>
                      </Border>
                      <Border Classes="StatCard">
                        <StackPanel Spacing="2">
                          <TextBlock Text="ID type" FontSize="11" Opacity="0.5"/>
                          <TextBlock Text="{Binding IdType}"
                                     FontSize="13" FontWeight="SemiBold"
                                     FontFamily="Monospace"/>
                        </StackPanel>
                      </Border>
                      <Border Classes="StatCard">
                        <StackPanel Spacing="2">
                          <TextBlock Text="Indexes" FontSize="11" Opacity="0.5"/>
                          <TextBlock Text="{Binding IndexList.Count}"
                                     FontSize="20" FontWeight="SemiBold"/>
                        </StackPanel>
                      </Border>
                    </StackPanel>
                  </StackPanel>

                  <!-- ── Tabs ── -->
                  <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}">

                    <!-- ── Tab: Documents ── -->
                    <TabItem Header="Documents">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" MinWidth="200"/>
                          <!-- Splitter column: Auto so it collapses to 0 when editor is hidden -->
                          <ColumnDefinition Width="Auto"/>
                          <!-- Editor column: * when open, 0px when closed -->
                          <ColumnDefinition Width="{ReflectionBinding IsEditorOpen,
                              Converter={x:Static converters:BoolToStarGridLengthConverter.Instance}}"
                                            MinWidth="0"/>
                        </Grid.ColumnDefinitions>

                        <!-- Table pane -->
                        <DockPanel Grid.Column="0">

                          <!-- Toolbar -->
                          <Border DockPanel.Dock="Top"
                                  Padding="8,6"
                                  BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                  BorderThickness="0,0,0,1">
                            <Button Content="+ New Document"
                                    Command="{Binding NewDocumentCommand}"
                                    HorizontalAlignment="Right"/>
                          </Border>

                          <!-- Pagination -->
                          <Border DockPanel.Dock="Bottom"
                                  BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                  BorderThickness="0,1,0,0"
                                  Padding="12,6">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                              <Button Grid.Column="0" Content="← Prev"
                                      IsEnabled="{Binding CanGoPrev}"
                                      Command="{Binding PrevPageCommand}"/>
                              <TextBlock Grid.Column="1"
                                         Text="{Binding CurrentPageDisplay}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         FontSize="12" Opacity="0.7"/>
                              <Button Grid.Column="2" Content="Next →"
                                      IsEnabled="{Binding CanGoNext}"
                                      Command="{Binding NextPageCommand}"/>
                            </Grid>
                          </Border>

                          <!-- Table -->
                          <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                  BorderThickness="0,1,0,0">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">
                              <StackPanel>
                                <Grid ColumnDefinitions="110,200,80,*"
                                      Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
                                  <TextBlock Grid.Column="0" Text="Actions"
                                             FontWeight="SemiBold" FontSize="12"
                                             Margin="10,7"/>
                                  <TextBlock Grid.Column="1" Text="_id"
                                             FontWeight="SemiBold" FontSize="12"
                                             FontFamily="Monospace" Margin="8,7"/>
                                  <TextBlock Grid.Column="2" Text="Size"
                                             FontWeight="SemiBold" FontSize="12"
                                             Margin="8,7"/>
                                  <TextBlock Grid.Column="3" Text="Fields"
                                             FontWeight="SemiBold" FontSize="12"
                                             Margin="8,7"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding Documents}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="ex:DocumentRowViewModel"
                                                  x:CompileBindings="False">
                                      <Grid ColumnDefinitions="110,200,80,*"
                                            Classes="DocRow">
                                        <StackPanel Grid.Column="0"
                                                    Orientation="Horizontal"
                                                    Spacing="4" Margin="6,4">
                                          <Button Content="Open"
                                                  FontSize="11"
                                                  Padding="6,2"
                                                  Command="{Binding DataContext.OpenRowCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ItemsControl}}"
                                                  CommandParameter="{Binding}"/>
                                          <Button Content="✕"
                                                  FontSize="11"
                                                  Padding="6,2"
                                                  Classes="DangerBtn"
                                                  Command="{Binding DataContext.DeleteDocumentCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ItemsControl}}"
                                                  CommandParameter="{Binding}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Id}"
                                                   FontFamily="Monospace"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding SizeDisplay}"
                                                   FontFamily="Monospace"
                                                   FontSize="11"
                                                   Opacity="0.65"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"
                                                   Margin="4,0,8,0"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding Content}"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0"/>
                                      </Grid>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </StackPanel>
                            </ScrollViewer>
                          </Border>
                        </DockPanel>

                        <!-- Drag-resizable splitter between list and editor -->
                        <GridSplitter Grid.Column="1"
                                      Width="5"
                                      ResizeDirection="Columns"
                                      IsVisible="{Binding IsEditorOpen}"
                                      Background="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                      Opacity="0.25"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"/>

                        <!-- ── Editor pane (right) ── -->
                        <Border Grid.Column="2"
                                MinWidth="260"
                                IsVisible="{Binding IsEditorOpen}"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="0">
                          <DockPanel>

                            <!-- Editor header -->
                            <Grid DockPanel.Dock="Top"
                                  ColumnDefinitions="*,Auto,Auto"
                                  Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                  Height="36">
                              <TextBlock Grid.Column="0"
                                         Text="{Binding EditorTitle}"
                                         FontFamily="Monospace" FontSize="12"
                                         TextTrimming="CharacterEllipsis"
                                         VerticalAlignment="Center"
                                         Margin="12,0"/>
                              <ToggleButton Grid.Column="1"
                                            Content="&#x1F333; Tree"
                                            FontSize="10"
                                            Padding="8,3"
                                            Margin="4,6"
                                            Height="24"
                                            IsChecked="{Binding EditorShowTree}"
                                            ToolTip.Tip="Toggle navigable JSON tree view"/>
                              <Button Grid.Column="2"
                                      Content="✕"
                                      Padding="8,0"
                                      Height="36"
                                      Command="{Binding CloseEditorCommand}"/>
                            </Grid>

                            <!-- Editor footer -->
                            <Border DockPanel.Dock="Bottom"
                                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="10,6">
                              <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding EditorMessage}"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Classes.MsgErr="{Binding EditorIsError}"
                                           Classes.MsgOk="{Binding EditorIsOk}"/>
                                <Button Grid.Column="1"
                                        Content="💾 Save"
                                        Command="{Binding SaveDocumentCommand}"/>
                              </Grid>
                            </Border>

                            <!-- JSON text / tree panel -->
                            <Grid>

                              <!-- Text editor -->
                              <TextBox AcceptsReturn="True"
                                       TextWrapping="NoWrap"
                                       Text="{Binding EditorJson}"
                                       FontFamily="Monospace"
                                       FontSize="12"
                                       BorderThickness="0"
                                       CornerRadius="0"
                                       IsVisible="{Binding !EditorShowTree}"/>

                              <!-- Navigable JSON tree -->
                              <ScrollViewer IsVisible="{Binding EditorShowTree}"
                                            HorizontalScrollBarVisibility="Auto"
                                            VerticalScrollBarVisibility="Auto">
                                <TreeView ItemsSource="{Binding JsonTreeRoots}"
                                          Margin="4,6"
                                          BorderThickness="0"
                                          Background="Transparent">
                                  <TreeView.Styles>
                                    <Style Selector="TreeViewItem">
                                      <Setter Property="IsExpanded" Value="{ReflectionBinding IsExpanded}"/>
                                    </Style>
                                  </TreeView.Styles>
                                  <TreeView.ItemTemplate>
                                    <TreeDataTemplate x:DataType="ex:JsonNodeViewModel"
                                                      ItemsSource="{Binding Children}">
                                      <StackPanel Orientation="Horizontal" Spacing="3">
                                        <TextBlock IsVisible="{Binding HasKey}"
                                                   Text="{Binding Key}"
                                                   FontFamily="Monospace" FontSize="11"
                                                   Foreground="#9CDCFE"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock IsVisible="{Binding HasKey}"
                                                   Text=": "
                                                   FontFamily="Monospace" FontSize="11"
                                                   Opacity="0.4"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding DisplayValue}"
                                                   FontFamily="Monospace" FontSize="11"
                                                   VerticalAlignment="Center"
                                                   Classes.JsonStr="{Binding IsString}"
                                                   Classes.JsonNum="{Binding IsNumber}"
                                                   Classes.JsonBool="{Binding IsBoolOrNull}"
                                                   Classes.JsonHint="{Binding IsContainer}"/>
                                      </StackPanel>
                                    </TreeDataTemplate>
                                  </TreeView.ItemTemplate>
                                </TreeView>
                              </ScrollViewer>

                            </Grid>
                          </DockPanel>
                        </Border>

                      </Grid>
                    </TabItem>

                    <!-- ── Tab: Indexes ── -->
                    <TabItem Header="Indexes">
                      <DockPanel Margin="20,16">

                        <!-- Create form (bottom) -->
                        <Border DockPanel.Dock="Bottom"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="0,14,0,0">
                          <StackPanel Spacing="10">
                            <TextBlock Text="Create New Index"
                                       FontWeight="SemiBold" FontSize="13"/>

                            <!-- Index Type Selector -->
                            <StackPanel Orientation="Horizontal" Spacing="24">
                              <RadioButton HorizontalAlignment="Left"
                                           Content="Standard (B-Tree)"
                                           IsChecked="{Binding IsBTreeIndexType}"/>
                              <RadioButton HorizontalAlignment="Left"
                                           Content="Vector (HNSW)"
                                           IsChecked="{Binding IsVectorIndexType}"/>
                              <RadioButton HorizontalAlignment="Left"
                                           Content="Geospatial (R-Tree)"
                                           IsChecked="{Binding IsSpatialIndexType}"/>
                            </StackPanel>

                            <Grid ColumnDefinitions="*,180,Auto,Auto">
                              <TextBox Grid.Column="0"
                                       Text="{Binding NewIndexField}"
                                       Watermark="Field path (e.g. metadata.age)"
                                       Margin="0,0,8,0"
                                       VerticalContentAlignment="Center"/>
                              <TextBox Grid.Column="1"
                                       Text="{Binding NewIndexName}"
                                       Watermark="Index name (optional)"
                                       Margin="0,0,8,0"
                                       VerticalContentAlignment="Center"/>
                              <CheckBox Grid.Column="2"
                                        Content="Unique"
                                        IsChecked="{Binding IsNewIndexUnique}"
                                        IsVisible="{Binding IsBTreeIndexType}"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"/>
                              <Button Grid.Column="3"
                                      Content="Create Index"
                                      Classes="PrimaryBtn"
                                      Command="{Binding CreateIndexCommand}"/>
                            </Grid>

                            <!-- Extra fields for Vector -->
                            <StackPanel Spacing="12"
                                        IsVisible="{Binding IsVectorIndexType}"
                                        Margin="0,4,0,0">
                              <Grid ColumnDefinitions="*,*">
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                  <TextBlock Text="Dimensions"
                                             FontSize="11" Opacity="0.5" Margin="2,0,0,4"/>
                                  <NumericUpDown Value="{Binding NewIndexDimensions}"
                                                 Minimum="1" Maximum="32768"
                                                 FormatString="0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                  <TextBlock Text="Metric"
                                             FontSize="11" Opacity="0.5" Margin="2,0,0,4"/>
                                  <ComboBox ItemsSource="{Binding AvailableMetrics}"
                                            SelectedItem="{Binding NewIndexMetric}"
                                            HorizontalAlignment="Stretch"/>
                                </StackPanel>
                              </Grid>
                            </StackPanel>

                            <TextBlock Text="{Binding IndexMessage}"
                                       FontSize="12"
                                       Classes.MsgErr="{Binding IndexIsError}"
                                       Classes.MsgOk="{Binding IndexIsOk}"
                                       IsVisible="{Binding IndexMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                          </StackPanel>
                        </Border>

                        <!-- Index list -->
                        <StackPanel Spacing="4">
                          <TextBlock Text="Secondary Indexes"
                                     FontWeight="SemiBold" FontSize="13"
                                     Margin="0,0,0,8"/>
                          <TextBlock Text="No indexes defined."
                                     Opacity="0.5" FontSize="12"
                                     IsVisible="{Binding HasNoIndexes}"/>
                          <ItemsControl ItemsSource="{Binding IndexList}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate x:DataType="core:DynamicIndexDescriptor">
                                <Grid ColumnDefinitions="*,Auto"
                                      Margin="0,0,0,6">
                                  <Border Classes="KeyRow"
                                          Grid.ColumnSpan="2"/>
                                  
                                  <StackPanel Grid.Column="0" Margin="14,10" Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                      <TextBlock Text="{Binding Name}"
                                                 FontWeight="SemiBold"
                                                 FontSize="13"/>
                                      <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                              CornerRadius="2"
                                              Padding="4,2">
                                        <TextBlock Text="{Binding Type}"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   Opacity="0.8"
                                                   VerticalAlignment="Center"/>
                                      </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding FieldPath}"
                                               FontFamily="Monospace"
                                               FontSize="12"
                                               Opacity="0.8"/>
                                    
                                    <!-- Options summary (Vector) -->
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="12"
                                                Opacity="0.6"
                                                IsVisible="{Binding IsVector}">
                                      <TextBlock FontSize="11"
                                                 Text="{Binding Dimensions, StringFormat='Dimensions: \{0\}'}"/>
                                      <TextBlock FontSize="11"
                                                 Text="{Binding Metric, StringFormat='Metric: \{0\}'}"/>
                                    </StackPanel>
                                  </StackPanel>

                                  <Button Grid.Column="1"
                                          Content="Drop"
                                          FontSize="11"
                                          Padding="8,3"
                                          Margin="14,0"
                                          Classes="DangerBtn"
                                          VerticalAlignment="Center"
                                          Command="{Binding $parent[ItemsControl].((ex:CollectionDetailViewModel)DataContext).DropIndexCommand}"
                                          CommandParameter="{Binding Name}"/>
                                </Grid>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>

                      </DockPanel>
                    </TabItem>

                    <!-- ── Tab: Schema (Metadata) ── -->
                    <TabItem Header="Schema">
                      <DockPanel Margin="20,16">
                        
                        <!-- Header / Info -->
                        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,20">
                          <TextBlock Text="Collection Schema &amp; Vector Sources" 
                                     FontWeight="SemiBold" FontSize="14"/>
                          <TextBlock Text="Configure how text fields are concatenated for vector embeddings (RAG)." 
                                     Opacity="0.6" FontSize="12"/>
                        </StackPanel>

                        <!-- Actions (Bottom) -->
                        <Border DockPanel.Dock="Bottom" 
                                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="0,16,0,0">
                          <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" 
                                       Text="{Binding SchemaMessage}" 
                                       FontSize="12" 
                                       VerticalAlignment="Center"
                                       Classes.MsgErr="{Binding SchemaIsError}"
                                       Classes.MsgOk="{Binding SchemaIsOk}"
                                       IsVisible="{Binding SchemaMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            <Button Grid.Column="1" 
                                    Content="Save Schema Configuration" 
                                    Classes="PrimaryBtn"
                                    Command="{Binding SaveSchemaCommand}"/>
                          </Grid>
                        </Border>

                        <!-- Vector Source Fields Configuration -->
                        <ScrollViewer>
                          <Grid ColumnDefinitions="*,340">
                             
                            <!-- Left col: Schema Fields (if present) -->
                            <StackPanel Grid.Column="0" Spacing="20" Margin="0,0,24,0">
                              <Border Background="White" 
                                      BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                      BorderThickness="1"
                                      CornerRadius="4" Padding="12">
                                <StackPanel Spacing="10">
                                  <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="Collection Schema (BSON Fields)" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="Suggest from Data" FontSize="10" Padding="8,2" Command="{Binding InferSchemaCommand}"/>
                                  </Grid>
                                  <TextBlock Text="Define the fields expected in this collection." Opacity="0.6" FontSize="11" Margin="0,0,0,4"/>
                                  
                                  <!-- New Field Form -->
                                  <Grid ColumnDefinitions="*,120,Auto" Margin="0,0,0,8">
                                    <TextBox Grid.Column="0" Text="{Binding NewSchemaFieldName}" Watermark="Field name" Margin="0,0,6,0"/>
                                    <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableBsonTypes}" SelectedItem="{Binding NewSchemaFieldType}" HorizontalAlignment="Stretch" Margin="0,0,6,0"/>
                                    <Button Grid.Column="2" Content="Add" Command="{Binding AddSchemaFieldCommand}"/>
                                  </Grid>

                                  <ItemsControl ItemsSource="{Binding SchemaFields}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate DataType="ex:SchemaFieldViewModel">
                                        <Grid ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,2">
                                          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Name}" FontFamily="Monospace" FontSize="12" VerticalAlignment="Center"/>
                                          </StackPanel>
                                          
                                          <ComboBox Grid.Column="1" ItemsSource="{Binding $parent[ItemsControl].((ex:CollectionDetailViewModel)DataContext).AvailableBsonTypes}" 
                                                    SelectedItem="{Binding Type}" FontSize="10" Padding="4,0" Margin="4,0" BorderThickness="0" Background="Transparent" VerticalAlignment="Center"/>
                                          
                                          <Button Grid.Column="2" Content="+ Use as Source" FontSize="10" Padding="8,2" Margin="4,0" 
                                                  Command="{Binding $parent[ItemsControl].((ex:CollectionDetailViewModel)DataContext).AddSourcedFieldFromSchemaCommand}" 
                                                  CommandParameter="{Binding}"/>
                                          
                                          <Button Grid.Column="3" Content="✕" Classes="DangerBtn" FontSize="10" Padding="6,2" 
                                                  Command="{Binding $parent[ItemsControl].((ex:CollectionDetailViewModel)DataContext).RemoveSchemaFieldCommand}" 
                                                  CommandParameter="{Binding}"/>
                                        </Grid>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </StackPanel>
                              </Border>

                              <!-- Manual Field List -->
                              <StackPanel Spacing="8">
                                <TextBlock Text="Vector Source Configuration" FontWeight="SemiBold" FontSize="12"/>
                                
                                <!-- Entry Form -->
                                <Border Background="White" 
                                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4" Padding="12">
                                  <StackPanel Spacing="10">
                                    <Grid ColumnDefinitions="*,*,*,Auto">
                                      <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="Field Path" FontSize="11" Opacity="0.5" Margin="2,0,0,4"/>
                                        <TextBox Text="{Binding NewVectorSourceFieldPath}" Watermark="e.g. title"/>
                                      </StackPanel>
                                      <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                        <TextBlock Text="Prefix (opt)" FontSize="11" Opacity="0.5" Margin="2,0,0,4"/>
                                        <TextBox Text="{Binding NewVectorSourcePrefix}" Watermark="e.g. Title: "/>
                                      </StackPanel>
                                      <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                        <TextBlock Text="Suffix (opt)" FontSize="11" Opacity="0.5" Margin="2,0,0,4"/>
                                        <TextBox Text="{Binding NewVectorSourceSuffix}" Watermark="e.g. \n"/>
                                      </StackPanel>
                                      <Button Grid.Column="3" Content="Add" VerticalAlignment="Bottom" Command="{Binding AddVectorSourceFieldCommand}"/>
                                    </Grid>
                                  </StackPanel>
                                </Border>

                                <!-- Current Fields -->
                                <ItemsControl ItemsSource="{Binding VectorSourceFields}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="ex:VectorSourceFieldViewModel">
                                      <Grid ColumnDefinitions="*,*,*,Auto" Margin="0,4">
                                        <Border Classes="KeyRow" Grid.ColumnSpan="4"/>
                                        <TextBlock Grid.Column="0" Text="{Binding Path}" FontFamily="Monospace" FontSize="12" Margin="10,6" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Prefix}" FontSize="12" Margin="10,6" VerticalAlignment="Center" Opacity="0.7"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Suffix}" FontSize="12" Margin="10,6" VerticalAlignment="Center" Opacity="0.7"/>
                                        <Button Grid.Column="3" Content="✕" Margin="6,4" Classes="DangerBtn" FontSize="10" Padding="6,2" Command="{Binding $parent[ItemsControl].((ex:CollectionDetailViewModel)DataContext).RemoveVectorSourceFieldCommand}" CommandParameter="{Binding}"/>
                                      </Grid>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>

                              </StackPanel>
                            </StackPanel>


                            <!-- Right Col: Config settings -->
                            <StackPanel Grid.Column="1" Spacing="20">
                              <Border Background="White" 
                                      BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                      BorderThickness="1"
                                      CornerRadius="4" Padding="12">
                                <StackPanel Spacing="12">
                                  <TextBlock Text="General Settings" FontWeight="SemiBold" FontSize="12"/>
                                  <StackPanel Spacing="4">
                                    <TextBlock Text="Field Separator" FontSize="11" Opacity="0.5" Margin="2,0"/>
                                    <TextBox Text="{Binding VectorSourceSeparator}" Watermark="e.g. space, newline, comma"/>
                                  </StackPanel>
                                </StackPanel>
                              </Border>
                            </StackPanel>

                          </Grid>
                        </ScrollViewer>
                        
                      </DockPanel>
                    </TabItem>

                    <!-- ── Tab: Query (BLQL) ── -->
                    <TabItem Header="Query">
                      <DockPanel>

                        <!-- ── Top: filter input area ── -->
                        <Border DockPanel.Dock="Top"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="12,10">
                          <StackPanel Spacing="8">

                            <!-- Filter -->
                            <TextBlock Text="BLQL Filter (JSON)"
                                       FontWeight="SemiBold" FontSize="12"/>
                            <TextBox AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     Text="{Binding BlqlFilterJson}"
                                     Watermark="e.g. { &quot;field&quot;: { &quot;$gt&quot;: 0 } }  — leave empty to match all"
                                     FontFamily="Monospace"
                                     FontSize="12"
                                     MinHeight="60"
                                     MaxHeight="140"/>

                            <!-- Sort + Skip + Take row -->
                            <Grid ColumnDefinitions="*,110,110">
                              <TextBox Grid.Column="0"
                                       Text="{Binding BlqlSortJson}"
                                       Watermark="Sort — e.g. { &quot;name&quot;: 1 }"
                                       FontFamily="Monospace"
                                       FontSize="12"
                                       VerticalContentAlignment="Center"
                                       Margin="0,0,8,0"/>
                              <TextBox Grid.Column="1"
                                       Text="{Binding BlqlSkip}"
                                       Watermark="Skip"
                                       FontFamily="Monospace"
                                       FontSize="12"
                                       VerticalContentAlignment="Center"
                                       Margin="0,0,6,0"/>
                              <TextBox Grid.Column="2"
                                       Text="{Binding BlqlTake}"
                                       Watermark="Take (max)"
                                       FontFamily="Monospace"
                                       FontSize="12"
                                       VerticalContentAlignment="Center"/>
                            </Grid>

                            <!-- Buttons + status -->
                            <Grid ColumnDefinitions="Auto,Auto,*">
                              <Button Grid.Column="0"
                                      Content="▶ Run Query"
                                      Command="{Binding RunBlqlQueryCommand}"
                                      FontWeight="SemiBold"
                                      Margin="0,0,8,0"/>
                              <Button Grid.Column="1"
                                      Content="✕ Clear"
                                      Command="{Binding ClearBlqlQueryCommand}"/>
                              <TextBlock Grid.Column="2"
                                         Text="{Binding BlqlStatusMessage}"
                                         VerticalAlignment="Center"
                                         FontSize="12"
                                         Margin="12,0,0,0"
                                         TextWrapping="Wrap"
                                         Classes.MsgErr="{Binding BlqlIsError}"
                                         Classes.MsgOk="{Binding BlqlStatusIsOk}"
                                         IsVisible="{Binding BlqlStatusMessage,
                                             Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            </Grid>

                          </StackPanel>
                        </Border>

                        <!-- ── Results grid ── -->
                        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="0,1,0,0">
                          <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                        VerticalScrollBarVisibility="Auto">
                            <StackPanel>

                              <!-- Header row -->
                              <Grid ColumnDefinitions="110,200,80,*"
                                    Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                    IsVisible="{Binding BlqlHasResults}">
                                <TextBlock Grid.Column="0" Text="Actions"
                                           FontWeight="SemiBold" FontSize="12"
                                           Margin="10,7"/>
                                <TextBlock Grid.Column="1" Text="_id"
                                           FontWeight="SemiBold" FontSize="12"
                                           FontFamily="Monospace" Margin="8,7"/>
                                <TextBlock Grid.Column="2" Text="Size"
                                           FontWeight="SemiBold" FontSize="12"
                                           Margin="8,7"/>
                                <TextBlock Grid.Column="3" Text="Fields"
                                           FontWeight="SemiBold" FontSize="12"
                                           Margin="8,7"/>
                              </Grid>

                              <!-- Result rows -->
                              <ItemsControl ItemsSource="{Binding BlqlResults}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate DataType="ex:DocumentRowViewModel"
                                                x:CompileBindings="False">
                                    <Grid ColumnDefinitions="110,200,80,*"
                                          Classes="DocRow">
                                      <StackPanel Grid.Column="0"
                                                  Orientation="Horizontal"
                                                  Spacing="4" Margin="6,4">
                                        <Button Content="Open"
                                                FontSize="11"
                                                Padding="6,2"
                                                Command="{Binding DataContext.OpenRowCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="✕"
                                                FontSize="11"
                                                Padding="6,2"
                                                Classes="DangerBtn"
                                                Command="{Binding DataContext.DeleteDocumentCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                      </StackPanel>
                                      <TextBlock Grid.Column="1"
                                                 Text="{Binding Id}"
                                                 FontFamily="Monospace"
                                                 FontSize="12"
                                                 TextTrimming="CharacterEllipsis"
                                                 VerticalAlignment="Center"
                                                 Margin="8,0"/>
                                      <TextBlock Grid.Column="2"
                                                 Text="{Binding SizeDisplay}"
                                                 FontFamily="Monospace"
                                                 FontSize="11"
                                                 Opacity="0.65"
                                                 VerticalAlignment="Center"
                                                 HorizontalAlignment="Right"
                                                 Margin="4,0,8,0"/>
                                      <TextBlock Grid.Column="3"
                                                 Text="{Binding Content}"
                                                 FontSize="12"
                                                 TextTrimming="CharacterEllipsis"
                                                 VerticalAlignment="Center"
                                                 Margin="8,0"/>
                                    </Grid>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>

                              <!-- Empty state -->
                              <TextBlock Text="Run a query to see results here."
                                         Opacity="0.4" FontSize="12"
                                         Margin="16,16"
                                         IsVisible="{Binding !BlqlHasResults}"/>

                            </StackPanel>
                          </ScrollViewer>
                        </Border>

                      </DockPanel>
                    </TabItem>

                    <!-- ── Tab: TimeSeries ── -->
                    <TabItem Header="TimeSeries">
                      <DockPanel Margin="20,16">

                        <!-- Header -->
                        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,14">
                          <TextBlock Text="TimeSeries Configuration"
                                     FontWeight="SemiBold" FontSize="14"/>
                          <TextBlock Text="Enable append-only, time-indexed storage with automatic retention-based pruning."
                                     Opacity="0.6" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Conversion warning -->
                        <Border DockPanel.Dock="Top"
                                CornerRadius="6"
                                Padding="14,11"
                                Margin="0,0,0,20"
                                Background="#2A2210"
                                BorderBrush="#6B5500"
                                BorderThickness="1">
                          <StackPanel Spacing="6">
                            <TextBlock Text="⚠  What happens when you enable TimeSeries on an existing collection"
                                       FontWeight="SemiBold" FontSize="12"
                                       Foreground="#E8C040"/>
                            <StackPanel Spacing="4" Margin="4,0,0,0">
                              <TextBlock FontSize="11" TextWrapping="Wrap" Foreground="#D0C090"
                                         Text="• Existing documents are NOT migrated. They stay in their original slotted pages and are never pruned by the retention policy."/>
                              <TextBlock FontSize="11" TextWrapping="Wrap" Foreground="#D0C090"
                                         Text="• All indexes (primary B-Tree and secondary) remain fully valid and continue to work for both old and new documents."/>
                              <TextBlock FontSize="11" TextWrapping="Wrap" Foreground="#D0C090"
                                         Text="• Only documents inserted after enabling TimeSeries are written to TS pages and are subject to automatic pruning."/>
                              <TextBlock FontSize="11" TextWrapping="Wrap" Foreground="#D0C090"
                                         Text="• This is a one-way operation — there is no built-in way to convert back to standard mode once enabled."/>
                            </StackPanel>
                          </StackPanel>
                        </Border>

                        <!-- Actions (Bottom) -->
                        <Border DockPanel.Dock="Bottom"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="0,16,0,0">
                          <Grid ColumnDefinitions="*,Auto,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding TsMessage}"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Classes.MsgErr="{Binding TsIsError}"
                                       Classes.MsgOk="{Binding TsIsOk}"
                                       IsVisible="{Binding TsMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            <Button Grid.Column="1"
                                    Content="⚡ Force Prune"
                                    Margin="0,0,8,0"
                                    IsVisible="{Binding IsTimeSeries}"
                                    Command="{Binding ForcePruneCommand}"/>
                            <Button Grid.Column="2"
                                    Content="Save TimeSeries Configuration"
                                    Classes="PrimaryBtn"
                                    Command="{Binding SaveTimeSeriesCommand}"/>
                          </Grid>
                        </Border>

                        <!-- Content -->
                        <ScrollViewer>
                          <StackPanel Spacing="20" MaxWidth="540">

                            <!-- Status badge -->
                            <Border CornerRadius="6"
                                    Padding="14,10"
                                    Background="{DynamicResource SystemControlBackgroundAltMediumHighBrush}">
                              <Grid ColumnDefinitions="Auto,*">
                                <Border Grid.Column="0"
                                        CornerRadius="4"
                                        Padding="8,4"
                                        Margin="0,0,14,0"
                                        Background="#1E6B3C"
                                        IsVisible="{Binding IsTimeSeries}">
                                  <TextBlock Text="TIME SERIES"
                                             FontSize="10" FontWeight="Bold"
                                             Foreground="#55DD88"
                                             VerticalAlignment="Center"/>
                                </Border>
                                <Border Grid.Column="0"
                                        CornerRadius="4"
                                        Padding="8,4"
                                        Margin="0,0,14,0"
                                        Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                        IsVisible="{Binding !IsTimeSeries}">
                                  <TextBlock Text="STANDARD"
                                             FontSize="10" FontWeight="Bold"
                                             Opacity="0.5"
                                             VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding TsRetentionLabel}"
                                           VerticalAlignment="Center"
                                           FontSize="12" Opacity="0.8"/>
                              </Grid>
                            </Border>

                            <!-- Form -->
                            <StackPanel Spacing="14">

                              <StackPanel Spacing="6">
                                <TextBlock Text="Timestamp / TTL field name"
                                           FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="The document field containing the timestamp (DateTime or Int64 ticks). Leave blank to use insertion time."
                                           Opacity="0.55" FontSize="11" TextWrapping="Wrap"/>
                                <TextBox Text="{Binding TsTtlFieldName}"
                                         Watermark="e.g.  timestamp   (optional — leave blank to use insertion time)"
                                         VerticalContentAlignment="Center"/>
                              </StackPanel>

                              <StackPanel Spacing="6">
                                <TextBlock Text="Retention (days)"
                                           FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="Pages whose newest entry is older than this threshold are freed automatically on insert."
                                           Opacity="0.55" FontSize="11" TextWrapping="Wrap"/>
                                <NumericUpDown Value="{Binding TsRetentionDays}"
                                               Minimum="0.001"
                                               Maximum="36500"
                                               Increment="1"
                                               FormatString="0.###"/>
                              </StackPanel>

                            </StackPanel>

                          </StackPanel>
                        </ScrollViewer>

                      </DockPanel>
                    </TabItem>

                  </TabControl>
                </Grid>
              </DataTemplate>

            </ContentControl.DataTemplates>
          </ContentControl>
        </Grid>
      </Grid>

    </Grid>
  </Grid>

  <Window.Styles>
    <Style Selector="Border.PresetCard">
      <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltMediumHighBrush}"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="10,10"/>
    </Style>

    <Style Selector="Border.RecentCard">
      <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltMediumHighBrush}"/>
      <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <Style Selector="Button.RecentCardBtn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="14,10"/>
      <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <Style Selector="Button.RecentRemoveBtn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
      <Setter Property="Padding" Value="10,0"/>
      <Setter Property="CornerRadius" Value="0,6,6,0"/>
      <Setter Property="VerticalAlignment" Value="Stretch"/>
      <Setter Property="FontSize" Value="11"/>
    </Style>

    <Style Selector="Border.Tag">
      <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>
      <Setter Property="CornerRadius" Value="3"/>
      <Setter Property="Padding" Value="6,2"/>
    </Style>

    <!-- ── Sidebar nav items ──────────────────────────────────────── -->
    <Style Selector="Button.NavItem">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="Padding" Value="12,7"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Margin" Value="4,1"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>
    <Style Selector="Button.NavItem:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}"/>
    </Style>
    <Style Selector="Button.NavItem.NavItemActive">
      <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
      <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.NavItem.NavItemActive:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
    </Style>

    <Style Selector="Button.NavRefreshBtn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="2,0"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>

    <!-- ── Detail panel ───────────────────────────────────────────── -->
    <Style Selector="Border.KeyRow">
      <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltMediumHighBrush}"/>
      <Setter Property="CornerRadius" Value="4"/>
    </Style>
    <Style Selector="Border.StatCard">
      <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltMediumHighBrush}"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="16,12"/>
      <Setter Property="MinWidth" Value="100"/>
    </Style>
    <Style Selector="Grid.DocRow">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Grid.DocRow:nth-child(even)">
      <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltMediumHighBrush}"/>
    </Style>
    <Style Selector="Grid.DocRow:pointerover">
      <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}"/>
    </Style>
    <Style Selector="TextBlock.MsgErr">
      <Setter Property="Foreground" Value="#E05555"/>
    </Style>
    <Style Selector="TextBlock.MsgOk">
      <Setter Property="Foreground" Value="#55AA55"/>
    </Style>
    <Style Selector="Button.DangerBtn">
      <Setter Property="Background" Value="#C0392B"/>
      <Setter Property="Foreground" Value="White"/>
    </Style>

    <!-- ── JSON tree node colours ─────────────────────────────────────── -->
    <Style Selector="TextBlock.JsonStr">
      <Setter Property="Foreground" Value="#CE9178"/>
    </Style>
    <Style Selector="TextBlock.JsonNum">
      <Setter Property="Foreground" Value="#B5CEA8"/>
    </Style>
    <Style Selector="TextBlock.JsonBool">
      <Setter Property="Foreground" Value="#569CD6"/>
    </Style>
    <Style Selector="TextBlock.JsonHint">
      <Setter Property="Opacity" Value="0.45"/>
      <Setter Property="FontStyle" Value="Italic"/>
    </Style>
  </Window.Styles>

</Window>
